<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.OffRecord" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:colorAccent">#6F8F72</item>
        <item name="colorPrimary">#6F8F72</item>
        <item name="colorPrimaryContainer">#E3EFE5</item>
        <item name="colorSecondary">#85B785</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="MyMaterialTimePickerTheme" parent="Theme.Material3.Light.Dialog">
        <item name="android:forceDarkAllowed">false</item>
        <item name="colorPrimary">#6F8F72</item>
    </style>

    <style name="Theme.OffRecord" parent="Base.Theme.OffRecord" />

    <!-- Custom Styles -->
    <style name="Widget.OffRecord.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_light</item>
    </style>

    <style name="Widget.OffRecord.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_main</item>
    </style>
</resources>
