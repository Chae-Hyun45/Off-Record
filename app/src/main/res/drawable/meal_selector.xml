<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state: Warm cream background + pastel yellow border -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/secondary_cream"/>
            <stroke android:width="2dp" android:color="@color/primary_pastel_yellow"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Unselected state: Subtle white background + light beige border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white"/>
            <stroke android:width="1dp" android:color="@color/accent_beige"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</selector>
