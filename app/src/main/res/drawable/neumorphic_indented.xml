<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top Left Inset Shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_dark" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Main Inset Surface (Offset to show top shadow) -->
    <item android:top="2dp" android:left="2dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_cream_ivory" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
