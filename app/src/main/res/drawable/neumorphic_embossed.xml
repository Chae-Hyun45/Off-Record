<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Right Shadow -->
    <item android:bottom="0dp" android:left="3dp" android:right="0dp" android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_dark" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <!-- Top Left Highlight -->
    <item android:bottom="3dp" android:left="0dp" android:right="3dp" android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_light" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <!-- Main Surface -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_cream_ivory" />
            <corners android:radius="30dp" />
        </shape>
    </item>
</layer-list>
