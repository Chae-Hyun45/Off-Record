<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow/Shadow -->
    <item android:bottom="0dp" android:left="2dp" android:right="0dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#33E6AF2E" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <!-- Main Liquid Gradient -->
    <item android:bottom="2dp" android:left="0dp" android:right="2dp" android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="@color/liquid_gold"
                android:startColor="@color/butter_yellow_main"
                android:type="linear" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>
