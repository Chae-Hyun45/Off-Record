<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/white_bubble_bg"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘은 어떤 하루였나요?"
        android:layout_marginBottom="12dp"/>

    <!-- dialog_emotion_select.xml 파일 내용 -->
    <!-- ... 상단 생략 ... -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton android:id="@+id/emo1" android:layout_width="60dp" android:layout_height="60dp"
            android:src="@drawable/one" android:background="@android:color/transparent" android:scaleType="fitCenter"/>
        <ImageButton android:id="@+id/emo2" android:layout_width="60dp" android:layout_height="60dp"
            android:src="@drawable/two" android:background="@android:color/transparent" android:scaleType="fitCenter"/>
        <ImageButton android:id="@+id/emo3" android:layout_width="60dp" android:layout_height="60dp"
            android:src="@drawable/three" android:background="@android:color/transparent" android:scaleType="fitCenter"/>
        <ImageButton android:id="@+id/emo4" android:layout_width="60dp" android:layout_height="60dp"
            android:src="@drawable/four" android:background="@android:color/transparent" android:scaleType="fitCenter"/>
        <ImageButton android:id="@+id/emo5" android:layout_width="60dp" android:layout_height="60dp"
            android:src="@drawable/five" android:background="@android:color/transparent" android:scaleType="fitCenter"/>
    </LinearLayout>
</LinearLayout>