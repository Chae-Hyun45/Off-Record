<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/white_bubble_bg"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘은 어떤 하루였나요?"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/emo1"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="4dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:clickable="true"
            android:contentDescription="emo1"
            android:focusable="true"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/one" />

        <ImageView
            android:id="@+id/emo2"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="4dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:clickable="true"
            android:contentDescription="emo2"
            android:focusable="true"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/two" />

        <ImageView
            android:id="@+id/emo3"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="4dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:clickable="true"
            android:contentDescription="emo3"
            android:focusable="true"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/three" />

        <ImageView
            android:id="@+id/emo4"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="4dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:clickable="true"
            android:contentDescription="emo4"
            android:focusable="true"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/four" />

        <ImageView
            android:id="@+id/emo5"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="4dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:clickable="true"
            android:contentDescription="emo5"
            android:focusable="true"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/five" />
    </LinearLayout>
</LinearLayout>
