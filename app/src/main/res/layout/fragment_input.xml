<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white_soft">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp">

            <TextView
                android:id="@+id/inputDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"
                android:fontFamily="sans-serif-black"
                android:text="2026년 5월 28일"
                android:textColor="@color/text_main"
                android:textSize="20sp" />

            <!-- Emotion Selector -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OffRecord.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:text="현재 기분은 어떤가요?"
                        android:textColor="@color/text_main"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/btnHappy"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="fitCenter"
                            android:src="@drawable/one" />

                        <ImageButton
                            android:id="@+id/btnSmile"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="fitCenter"
                            android:src="@drawable/two" />

                        <ImageButton
                            android:id="@+id/btnNeutral"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="fitCenter"
                            android:src="@drawable/three" />

                        <ImageButton
                            android:id="@+id/btnSad"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="fitCenter"
                            android:src="@drawable/four" />

                        <ImageButton
                            android:id="@+id/btnAngry"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:scaleType="fitCenter"
                            android:src="@drawable/five" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sliders -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OffRecord.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="상태 체크"
                        android:textColor="@color/text_main"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="에너지 레벨"
                        android:textColor="@color/text_sub"
                        android:textSize="13sp" />
                    <SeekBar
                        android:id="@+id/energySeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:max="100"
                        android:progress="70"
                        android:progressTint="@color/brand_primary"
                        android:thumbTint="@color/brand_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="기분 점수"
                        android:textColor="@color/text_sub"
                        android:textSize="13sp" />
                    <SeekBar
                        android:id="@+id/scoreSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="@color/brand_secondary"
                        android:thumbTint="@color/brand_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Journal Input -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OffRecord.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="오늘의 기록"
                        android:textColor="@color/text_main"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-bold" />

                    <EditText
                        android:id="@+id/etDiary"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:background="@color/bg_white_soft"
                        android:gravity="top"
                        android:hint="여기에 소중한 기록을 남겨주세요."
                        android:inputType="textMultiLine"
                        android:padding="16dp"
                        android:textColor="@color/text_main"
                        android:textSize="15sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnComplete"
                style="@style/Widget.OffRecord.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="기록 저장하기" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
